            stopWebcam();

            const reader = new FileReader();
            reader.onload = function(e) {
                const imgPreview = document.getElementById('imagePreview');
                imgPreview.src = e.target.result;
                imgPreview.classList.remove('hidden');
                document.getElementById('cameraMockup').classList.add('hidden');

                // Determine pseudo class based on file name or generic analysis pipeline
                const mockKeys = ['ramen', 'pet', 'box', 'delivery'];
                const matchedKey = mockKeys.find(k => file.name.toLowerCase().includes(k)) || 'pet';
                executeAIScan(matchedKey);
            };
            reader.readAsDataURL(file);
        }

