        function renderMapMarkers(filterType) {
            mapMarkers.forEach(marker => map.removeLayer(marker));
            mapMarkers = [];

            const filteredData = filterType === 'all' 
                ? mapLocations 
                : mapLocations.filter(loc => loc.type === filterType);

            filteredData.forEach(loc => {
                let markerColor = '#10b981'; // green (cleanzone)
                if (loc.type === 'recycle') markerColor = '#6366f1'; // blue/indigo (recycle bin)
                if (loc.type === 'clothing') markerColor = '#f97316'; // orange (clothes)

                const markerIcon = L.divIcon({
                    className: 'custom-div-icon',
                    html: `<div style="background-color: ${markerColor}; width: 14px; height: 14px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.4)"></div>`,
                    iconSize: [14, 14],
                    iconAnchor: [7, 7]
                });

                let localeName = loc[`name_${currentLang}`] || loc.name_ko;
                let popupContent = `
                    <div style="font-family: Pretendard, sans-serif; width:160px;">
                        <strong style="font-size:12px; color:#1e293b; display:block; margin-bottom:4px;">${localeName}</strong>
                        <span style="font-size:10px; color:#64748b; display:block;">${loc.desc}</span>
                        <span style="font-size:9px; background:#f1f5f9; color:#475569; padding:2px 6px; border-radius:4px; display:inline-block; margin-top:6px;">
                            ${loc.type === 'cleanzone' ? '스마트클린존' : loc.type === 'recycle' ? '폐가전수거' : '의류수거함'}
                        </span>
                    </div>
                `;

                const marker = L.marker(loc.coords, { icon: markerIcon })
                    .bindPopup(popupContent)
                    .addTo(map);
                
                mapMarkers.push(marker);
            });
        }

        function filterMarkers(category) {
            document.querySelectorAll("[id^='filterBtn-']").forEach(btn => {
                btn.className = "w-full text-left p-3 rounded-xl border border-slate-100 hover:bg-slate-50 text-xs font-medium flex items-center justify-between";
            });

            const activeBtn = document.getElementById('filterBtn-' + category);
            activeBtn.className = "w-full text-left p-3 rounded-xl border-2 border-brand-500 bg-brand-50/20 text-xs font-bold flex items-center justify-between";

            renderMapMarkers(category);

            const filteredData = category === 'all' ? mapLocations : mapLocations.filter(loc => loc.type === category);
            if (filteredData.length > 0) {
                map.panTo(filteredData[0].coords);
            }
        }

        function rebuildMapPopups() {
            if (mapMarkers.length > 0) {
                const activeFilter = document.querySelector(".border-brand-500[id^='filterBtn-']").id.replace('filterBtn-', '');
                renderMapMarkers(activeFilter);
            }
        }
    </script>
</body>
</html>
