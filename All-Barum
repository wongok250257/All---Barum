        // Real Camera Device activation
        async function startWebcam() {
            const video = document.getElementById('webcam');
            const cameraMockup = document.getElementById('cameraMockup');
            const captureBtn = document.getElementById('captureBtn');
            const imagePreview = document.getElementById('imagePreview');

            imagePreview.classList.add('hidden');

            try {
                if (stream) {
                    stopWebcam();
                }
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                video.srcObject = stream;
                video.classList.remove('hidden');
                cameraMockup.classList.add('hidden');
                captureBtn.disabled = false;
                
                // Show laser scanner line when webcam starts
                document.getElementById('scannerLine').classList.remove('hidden');
            } catch (err) {
                console.error("Camera access failed, falling back to simulated analysis", err);
                showAlert("<i class='fa-solid fa-triangle-exclamation text-amber-500'></i> 실제 카메라를 감지하지 못했습니다. 안심하세요! 아래 'AI 분석 테스트용 샘플'을 클릭하거나 디바이스 사진 올리기를 통해 스마트 분석을 동일하게 체험할 수 있습니다.");
            }
        }

        function stopWebcam() {
            const video = document.getElementById('webcam');
            const cameraMockup = document.getElementById('cameraMockup');
            const captureBtn = document.getElementById('captureBtn');
            const scannerLine = document.getElementById('scannerLine');

            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                stream = null;
            }
            video.classList.add('hidden');
            cameraMockup.classList.remove('hidden');
            captureBtn.disabled = true;
            scannerLine.classList.add('hidden');
        }

        // Trigger capture and run AI model prediction pipeline
        function triggerCapture() {
            if (!stream) return;
            
            // Shutter effect visual flashing
            const viewfinder = document.getElementById('webcam').parentElement;
            viewfinder.classList.add('opacity-40');
            setTimeout(() => {
                viewfinder.classList.remove('opacity-40');
            }, 150);

            // Mock photo analysis simulation using standard smart classifications
            const mockKeys = ['ramen', 'pet', 'box', 'delivery'];
            const randomSample = mockKeys[Math.floor(Math.random() * mockKeys.length)];
            
            stopWebcam();
            executeAIScan(randomSample);
        }

